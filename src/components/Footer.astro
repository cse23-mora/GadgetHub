---
import "../styles/global.css";
---

<style>
  footer {
    border-top: 1px solid rgba(129, 241, 51, 0.1);
    background: rgba(13, 10, 20, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 22px 24px;
    text-align: center;
    position: relative;
    z-index: 10;
  }

  footer p {
    font-size: 0.78rem;
    color: rgba(232, 244, 255, 0.4);
    letter-spacing: 0.05em;
    margin-bottom: 4px;
    font-family: 'Exo 2', sans-serif;
  }

  footer p .highlight { color: #81f133; font-weight: 600; }
  footer p .heart { color: #ff2d78; }
</style>

<footer>
  <p><span class="highlight">GadgetHub.cse23.org</span> — All tools run locally in your browser. No servers. No third-party access.</p>
  <p>Special thanks to all contributors of GadgetHub on GitHub <span class="heart"></span></p>
</footer>