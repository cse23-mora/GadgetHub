---
import "../styles/global.css";
---

<style>
  footer {
    border-top: 1px solid var(--footer-border);
    background: var(--footer-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 22px 24px;
    text-align: center;
    position: relative;
    z-index: 10;
    transition: background 0.3s, border-color 0.3s;
  }

  footer p {
    font-size: 0.78rem;
    color: var(--footer-text);
    letter-spacing: 0.05em;
    margin-bottom: 4px;
    font-family: 'Exo 2', sans-serif;
  }

  footer p .highlight { color: var(--footer-highlight); font-weight: 600; }
  footer p .heart { color: #c837ab; }
</style>

<footer>
  <p><span class="highlight">GadgetHub.cse23.org</span> — All tools run locally in your browser. No servers. No third-party access.</p>
  <p>Special thanks to all contributors of GadgetHub on GitHub <span class="heart"></span></p>
</footer>