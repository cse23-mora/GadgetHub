---
import "../styles/global.css";
---
<style>
  #preloader {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--preloader-bg, #1a1428);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    transition: opacity 0.5s ease;
  }

  #preloader.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .spinner {
    border: 3px solid var(--spinner-border, rgba(129,241,51,0.15));
    border-top: 3px solid var(--spinner-top, #81f133);
    border-radius: 50%;
    width: 50px;
    height: 50px;
    animation: spin 1s linear infinite;
    box-shadow: 0 0 20px var(--spinner-glow, rgba(129,241,51,0.25));
  }

  @keyframes spin {
    0%   { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
</style>

<div id="preloader">
  <div class="spinner"></div>
</div>

<script type="module">
  window.addEventListener('load', () => {
    const preloader = document.getElementById('preloader');
    preloader.classList.add('hidden');
  });
</script>
