---
import "../styles/global.css";
---

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(13, 10, 20, 0.8);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(129, 241, 51, 0.12);
  }

  .nav-link {
    font-family: 'Exo 2', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(240, 253, 244, 0.6);
    text-decoration: none;
    padding: 7px 18px;
    border: 1px solid rgba(129, 241, 51, 0.2);
    border-radius: 6px;
    transition: color 0.25s, border-color 0.25s, box-shadow 0.25s, background 0.25s;
    position: relative;
    overflow: hidden;
  }

  .nav-link:hover {
    color: #81f133;
    border-color: #81f133;
    box-shadow: 0 0 12px rgba(129, 241, 51, 0.3);
    background: rgba(129, 241, 51, 0.06);
  }

  /* Mobile menu */
  #mobile-menu {
    display: none;
    flex-direction: column;
    gap: 8px;
    background: rgba(13, 10, 20, 0.97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-top: 1px solid rgba(129, 241, 51, 0.12);
    padding: 16px 20px;
  }

  #mobile-menu.open {
    display: flex;
  }

  .menu-toggle {
    background: transparent;
    border: 1px solid rgba(129, 241, 51, 0.3);
    border-radius: 6px;
    color: #81f133;
    padding: 6px 12px;
    font-size: 1.2rem;
    cursor: pointer;
    transition: border-color 0.25s, box-shadow 0.25s;
  }

  .menu-toggle:hover {
    border-color: #00d4ff;
    box-shadow: 0 0 10px rgba(0, 212, 255, 0.3);
  }
</style>

<header class="w-full">
  <div class="max-w-7xl mx-auto flex items-center justify-between px-6 h-[68px]">
    <!-- Logo -->
    <a href="/" class="flex items-center">
      <img src="/logo-header.png" alt="GadgetHub Logo" class="h-11 w-auto" />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex gap-2">
      <a href="/" class="nav-link">Home</a>
      <a href="/text-tool" class="nav-link">Text Tool</a>
      <a href="/pdf-converter" class="nav-link">PDF Converter</a>
      <a href="#about" class="nav-link">About</a>
    </nav>

    <!-- Mobile hamburger -->
    <button
      class="menu-toggle md:hidden"
      id="hamburger"
      aria-label="Toggle navigation"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      ☰
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" role="navigation" aria-label="Mobile navigation">
    <a href="/" class="nav-link text-center">Home</a>
    <a href="/text-tool" class="nav-link text-center">Text Tool</a>
    <a href="/pdf-converter" class="nav-link text-center">PDF Converter</a>
    <a href="#about" class="nav-link text-center">About</a>
  </div>
</header>

<script>
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobile-menu');

  hamburger?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('open');
    hamburger.setAttribute('aria-expanded', String(isOpen));
  });
</script>