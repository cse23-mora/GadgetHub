---
import "../styles/global.css";
---

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--surface);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border-subtle);
    transition: background 0.3s, border-color 0.3s;
  }

  .nav-link {
    font-family: 'Exo 2', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--nav-link-color);
    text-decoration: none;
    padding: 7px 18px;
    border: 1px solid var(--nav-link-border);
    border-radius: 6px;
    transition: color 0.25s, border-color 0.25s, box-shadow 0.25s, background 0.25s;
    position: relative;
    overflow: hidden;
  }

  .nav-link:hover {
    color: var(--nav-link-hover);
    border-color: var(--nav-link-hover);
    background: rgba(129, 241, 51, 0.06);
  }

  html.light .nav-link:hover {
    background: rgba(88, 43, 126, 0.07);
  }

  /* Theme toggle */
  .theme-toggle {
    background: transparent;
    border: 1px solid var(--nav-link-border);
    border-radius: 6px;
    color: var(--nav-link-color);
    padding: 6px 14px;
    font-size: 0.9rem;
    cursor: pointer;
    transition: border-color 0.25s, box-shadow 0.25s, color 0.25s;
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: 'Exo 2', sans-serif;
    font-weight: 600;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .theme-toggle:hover {
    border-color: var(--nav-link-hover);
    color: var(--nav-link-hover);
    box-shadow: 0 0 10px rgba(129, 241, 51, 0.2);
  }

  html.light .theme-toggle:hover {
    box-shadow: 0 0 10px rgba(88, 43, 126, 0.2);
  }

  .toggle-icon { font-size: 1rem; }

  /* Mobile menu */
  #mobile-menu {
    display: none;
    flex-direction: column;
    gap: 8px;
    background: var(--surface-mobile);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-top: 1px solid var(--border-subtle);
    padding: 16px 20px;
    transition: background 0.3s;
  }

  #mobile-menu.open {
    display: flex;
  }

  .menu-toggle {
    background: transparent;
    border: 1px solid var(--nav-link-border);
    border-radius: 6px;
    color: var(--nav-link-color);
    padding: 6px 12px;
    font-size: 1.2rem;
    cursor: pointer;
    transition: border-color 0.25s, box-shadow 0.25s;
  }

  .menu-toggle:hover {
    border-color: var(--nav-link-hover);
    box-shadow: 0 0 10px rgba(129, 241, 51, 0.2);
  }
</style>

<header class="w-full">
  <div class="max-w-7xl mx-auto flex items-center justify-between px-6 h-[68px]">
    <!-- Logo -->
    <a href="/" class="flex items-center">
      <img src="/logo-header.png" alt="GadgetHub Logo" class="h-11 w-auto" />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex gap-2 items-center">
      <a href="/" class="nav-link">Home</a>
      <a href="/text-tool" class="nav-link">Text Tool</a>
      <a href="/pdf-converter" class="nav-link">PDF Converter</a>
      <a href="#about" class="nav-link">About</a>
      <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
        <span class="toggle-icon" id="toggle-icon">☀️</span>
        <span id="toggle-label">Light</span>
      </button>
    </nav>

    <!-- Mobile hamburger -->
    <div class="flex gap-2 md:hidden items-center">
      <button class="theme-toggle" id="theme-toggle-mobile" aria-label="Toggle theme">
        <span class="toggle-icon" id="toggle-icon-mobile">☀️</span>
      </button>
      <button
        class="menu-toggle"
        id="hamburger"
        aria-label="Toggle navigation"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        ☰
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" role="navigation" aria-label="Mobile navigation">
    <a href="/" class="nav-link text-center">Home</a>
    <a href="/text-tool" class="nav-link text-center">Text Tool</a>
    <a href="/pdf-converter" class="nav-link text-center">PDF Converter</a>
    <a href="#about" class="nav-link text-center">About</a>
  </div>
</header>

<script>
  // ── Hamburger ──
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobile-menu');
  hamburger?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('open');
    hamburger.setAttribute('aria-expanded', String(isOpen));
  });

  // ── Theme toggle ──
  const html = document.documentElement;
  const stored = localStorage.getItem('gh-theme');
  if (stored !== 'dark') html.classList.add('light');

  function syncToggleUI() {
    const isLight = html.classList.contains('light');
    const icon  = document.getElementById('toggle-icon');
    const label = document.getElementById('toggle-label');
    const iconM = document.getElementById('toggle-icon-mobile');
    if (icon)  icon.textContent  = isLight ? '🌙' : '🔅';
    if (label) label.textContent = isLight ? 'Dark' : 'Light';
    if (iconM) iconM.textContent = isLight ? '🌙' : '🔅';
  }

  syncToggleUI();

  function toggleTheme() {
    html.classList.toggle('light');
    localStorage.setItem('gh-theme', html.classList.contains('light') ? 'light' : 'dark');
    syncToggleUI();
  }

  document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
  document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);
</script>