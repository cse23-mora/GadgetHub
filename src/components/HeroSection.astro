---
import "../styles/global.css";
---


<section class="text-center py-10">
  <h1 class="text-4xl font-bold mb-4">Welcome to GadgetHub</h1>
  <p class="text-lg max-w-2xl mx-auto mb-6">
    GadgetHub is a collection of everyday tools that run directly in your
    browser. No servers. No third-party access. Everything happens locally on
    your device.
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-3xl mx-auto">
    <a href="/text-tool" class="p-6 bg-white shadow rounded-lg hover:bg-gray-50">
      <h2 class="text-xl font-semibold mb-2">📝 Text Tool</h2>
      <p>Convert and manipulate text quickly, right in your browser.</p>
    </a>
    <a href="/pdf-converter" class="p-6 bg-white shadow rounded-lg hover:bg-gray-50">
      <h2 class="text-xl font-semibold mb-2">📄 PDF Converter</h2>
      <p>Work with PDFs without uploading them anywhere.</p>
    </a>
  </div>
</section>