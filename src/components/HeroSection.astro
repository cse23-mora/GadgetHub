---
import "../styles/global.css";
---

<style>
  /* Hero */
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 14px;
    padding: 36px 24px 32px;
    animation: fadeUp 0.8s ease both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero-title {
    font-family: 'Orbitron', monospace;
    font-size: clamp(1.6rem, 3.5vw, 2.6rem);
    font-weight: 900;
    letter-spacing: 0.04em;
    /* Dark mode: green → teal → pink → purple (all vivid, all visible on dark) */
    background: linear-gradient(135deg, #81f133 0%, #15ffe0 40%, #c837ab 75%, #582b7e 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.25;
    margin: 0;
    padding: 0;
  }

  /* Light mode: replace pale teal midpoint with a deeper teal so it stays visible on white */
  html.light .hero-title {
    background: linear-gradient(135deg, #4a9a0a 0%, #007a6a 40%, #c837ab 75%, #3d1a5c 100%);
    -webkit-background-clip: text;
    background-clip: text;
  }

  .hero-sub {
    font-size: 1rem;
    color: var(--text-dim);
    max-width: 520px;
    line-height: 1.7;
    font-weight: 300;
    margin: 0;
    padding: 0;
  }

  /* Card grid */
  .card-grid {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 28px;
    padding: 16px 24px 48px;
    animation: fadeUp 0.9s 0.2s ease both;
  }

  /* Tool card */
  .tool-card {
    width: 320px;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(129, 241, 51, 0.2);
    background: var(--surface-card);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow:
      0 0 40px rgba(129, 241, 51, 0.07),
      0 0 80px rgba(88, 43, 126, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.07);
    transition: transform 0.35s, box-shadow 0.35s, background 0.3s;
    position: relative;
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .tool-card::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 17px;
    background: linear-gradient(135deg, rgba(129, 241, 51, 0.4), rgba(88, 43, 126, 0.4), rgba(21, 255, 224, 0.3));
    z-index: -1;
    animation: borderPulse 4s ease-in-out infinite;
  }

  @keyframes borderPulse {
    0%, 100% { opacity: 0.2; }
    50%       { opacity: 0.55; }
  }

  .tool-card:hover {
    transform: translateY(-8px) scale(1.01);
    box-shadow:
      0 0 60px rgba(129, 241, 51, 0.15),
      0 0 120px rgba(88, 43, 126, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }

  /* Card image area */
  .card-img {
    height: 140px;
    background: var(--card-img-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
  }

  .card-img::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, rgba(129, 241, 51, 0.05), rgba(88, 43, 126, 0.12));
  }

  .img-content {
    display: flex;
    align-items: center;
    gap: 20px;
    position: relative;
    z-index: 1;
  }

  .file-stack {
    display: flex;
    position: relative;
    width: 80px;
    height: 80px;
  }

  .file-icon {
    position: absolute;
    width: 54px;
    height: 66px;
    border-radius: 6px;
    border: 2px solid;
  }

  .file-icon:nth-child(1) { background: #3a8a2e; border-color: #81f133; top: 14px; left: 18px; transform: rotate(8deg); }
  .file-icon:nth-child(2) { background: #2a6622; border-color: #4ecb2a; top: 8px; left: 10px; transform: rotate(3deg); }
  .file-icon:nth-child(3) { background: #81f133; border-color: #15ffe0; top: 0; left: 0; }

  .arrow-icon {
    font-size: 2rem;
    color: #15ffe0;
    text-shadow: 0 0 16px #15ffe0;
    animation: arrowPulse 1.5s ease-in-out infinite;
  }

  @keyframes arrowPulse {
    0%, 100% { transform: translateX(0); opacity: 1; }
    50%       { transform: translateX(5px); opacity: 0.7; }
  }

  .pdf-icon {
    width: 64px;
    height: 76px;
    background: linear-gradient(160deg, #ff2d78, #7b2fff);
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-family: 'Orbitron', monospace;
    font-weight: 900;
    font-size: 0.85rem;
    color: white;
    box-shadow: 0 0 20px rgba(255, 45, 120, 0.4);
    position: relative;
  }

  .pdf-icon::before {
    content: '';
    position: absolute;
    top: -8px;
    right: -8px;
    width: 20px;
    height: 20px;
    background: var(--card-corner);
    clip-path: polygon(0 0, 100% 100%, 0 100%);
  }

  /* Card body */
  .card-body {
    padding: 22px 20px 18px;
    background: var(--card-body-bg);
    transition: background 0.3s;
  }

  .card-title-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }

  .card-title {
    font-family: 'Orbitron', monospace;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-main);
    letter-spacing: 0.03em;
  }

  .badge {
    font-size: 0.65rem;
    font-weight: 700;
    font-family: 'Orbitron', monospace;
    letter-spacing: 0.08em;
    padding: 3px 10px;
    border-radius: 20px;
    background: linear-gradient(135deg, #c837ab, #582b7e);
    color: white;
    box-shadow: 0 0 10px rgba(200, 55, 171, 0.4);
  }

  .card-desc {
    font-size: 0.82rem;
    color: var(--text-dim);
    line-height: 1.65;
    margin-bottom: 16px;
    font-weight: 300;
  }

  .card-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 20px;
    border: 1px solid;
    transition: filter 0.2s, box-shadow 0.2s;
  }

  .tag:hover { filter: brightness(1.3); box-shadow: 0 0 10px currentColor; }
  .tag-safe   { color: #81f133; border-color: rgba(129, 241, 51,  0.4); background: rgba(129, 241, 51,  0.08); }
  .tag-secure { color: #15ffe0; border-color: rgba(21,  255, 224, 0.4); background: rgba(21,  255, 224, 0.08); }
  .tag-local  { color: #c837ab; border-color: rgba(200, 55,  171, 0.4); background: rgba(200, 55,  171, 0.08); }

  /* Light mode tag overrides for contrast */
  html.light .tag-safe   { color: #3a8a10; background: rgba(129, 241, 51,  0.12); }
  html.light .tag-secure { color: #006d5e; border-color: rgba(0, 191, 165, 0.5); background: rgba(0, 191, 165, 0.10); }
  html.light .tag-local  { color: #582b7e; background: rgba(88, 43, 126, 0.10); }
</style>

<section style="position: relative; z-index: 1;">
  <!-- Hero text -->
  <div class="hero">
    <h1 class="hero-title">Welcome to GadgetHub</h1>
    <p class="hero-sub">
      A collection of everyday tools that run directly in your browser.
      No servers. No third-party access. Everything happens locally on your device.
    </p>
  </div>

  <!-- Cards -->
  <div class="card-grid">
    <a href="https://img2pdf.cse23.org" class="tool-card">
      <div class="card-img">
        <div class="img-content">
          <div class="file-stack">
            <div class="file-icon"></div>
            <div class="file-icon"></div>
            <div class="file-icon"></div>
          </div>
          <span class="arrow-icon">→</span>
          <div class="pdf-icon">PDF</div>
        </div>
      </div>
      <div class="card-body">
        <div class="card-title-row">
          <span class="card-title">Image to PDF Converter</span>
          <span class="badge">FREE</span>
        </div>
        <p class="card-desc">
          Quickly convert your JPG or PNG images into a single PDF.
          100% safe, secure, and processed directly in your browser —
          your files never leave your device.
        </p>
        <div class="card-tags">
          <span class="tag tag-safe">Safe</span>
          <span class="tag tag-secure">Secure</span>
          <span class="tag tag-local">Local</span>
        </div>
      </div>
    </a>
  </div>
</section>